@page
@model WebDispatcher.Areas.Identity.Pages.Account.Manage.IndexModel
@{
    ViewData["Title"] = "Profil";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h2 class="manage-section-title">Profil</h2>
<partial name="_StatusMessage" model="Model.StatusMessage"/>

<form id="profile-form" method="post" class="manage-form">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

    <div class="mb-3">
        <label asp-for="Username" class="form-label">Nom d'utilisateur</label>
        <input asp-for="Username" class="form-control" disabled/>
    </div>

    <div class="mb-4">
        <label asp-for="Input.PhoneNumber" class="form-label">Téléphone</label>
        <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Optionnel"/>
        <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
    </div>

    <button type="submit" class="btn btn-jira-primary">Enregistrer</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
