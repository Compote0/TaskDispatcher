@page
@model WebDispatcher.Areas.Identity.Pages.Account.Manage.EmailModel
@{
    ViewData["Title"] = "E-mail";
    ViewData["ActivePage"] = ManageNavPages.Email;
}

<h2 class="manage-section-title">E-mail</h2>
<partial name="_StatusMessage" model="Model.StatusMessage"/>

<form id="email-form" method="post" class="manage-form">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label class="form-label">E-mail actuel</label>
        <input value="@Model.Email" class="form-control" disabled/>
        @if (Model.IsEmailConfirmed)
        {
            <span class="badge bg-success mt-2">Confirmé</span>
        }
        else
        {
            <span class="badge bg-warning text-dark mt-2">Non confirmé</span>
        }
    </div>

    <div class="mb-4">
        <label asp-for="Input.NewEmail" class="form-label">Nouvel e-mail</label>
        <input asp-for="Input.NewEmail" class="form-control" autocomplete="email"/>
        <span asp-validation-for="Input.NewEmail" class="text-danger small"></span>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <button id="change-email-button" type="submit" asp-page-handler="ChangeEmail"
                class="btn btn-jira-primary">Changer l'e-mail</button>
        @if (!Model.IsEmailConfirmed)
        {
            <button id="email-verification" type="submit" asp-page-handler="SendVerificationEmail"
                    class="btn btn-outline-secondary">Renvoyer la confirmation</button>
        }
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
