@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <div class="jira-user-menu dropdown">
        <button class="btn btn-jira-icon dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
            <span class="avatar-circle avatar-md">@(User.Identity?.Name?[0].ToString().ToUpper())</span>
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
            <li><span class="dropdown-item-text small text-muted">@User.Identity?.Name</span></li>
            <li><hr class="dropdown-divider"/></li>
            <li>
                <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">Mon compte</a>
            </li>
            <li>
                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home")">
                    <button type="submit" class="dropdown-item">Déconnexion</button>
                </form>
            </li>
        </ul>
    </div>
}
else
{
    <a class="btn btn-sm btn-outline-secondary" asp-area="Identity" asp-page="/Account/Login">Connexion</a>
    <a class="btn btn-sm btn-jira-primary" asp-area="Identity" asp-page="/Account/Register">Inscription</a>
}
