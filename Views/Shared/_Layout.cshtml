<!DOCTYPE html>
<html lang="fr" data-bs-theme="dark">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - TaskDispatcher</title>
    <script>
        (function () {
            var t = localStorage.getItem('td-theme') || 'dark';
            document.documentElement.setAttribute('data-bs-theme', t);
        })();
    </script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/WebDispatcher.styles.css" asp-append-version="true"/>
</head>
<body class="app-body">

<div id="toast-container" class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index:9999"></div>

<header class="jira-header">
    <nav class="jira-nav">
        <div class="jira-nav-left">
            <a class="jira-logo" asp-controller="Home" asp-action="Index">
                <svg width="24" height="24" viewBox="0 0 32 32" fill="none">
                    <path d="M4 24L16 8L28 24H4Z" fill="#0052CC"/>
                    <path d="M10 24L16 16L22 24H10Z" fill="#2684FF"/>
                </svg>
                <span>TaskDispatcher</span>
            </a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <form class="d-none d-md-flex" asp-controller="Projects" asp-action="Index" method="get">
                    <input type="search" name="q" class="jira-search-input" placeholder="🔍  Rechercher..."/>
                </form>
            }
        </div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <ul class="jira-nav-links d-none d-lg-flex">
                <li><a asp-controller="Home" asp-action="Index" class="jira-nav-link">Pour vous</a></li>
                <li><a asp-controller="Projects" asp-action="Index" class="jira-nav-link">Espaces</a></li>
                <li class="dropdown">
                    <button class="jira-nav-link border-0 bg-transparent dropdown-toggle d-flex align-items-center gap-1"
                            data-bs-toggle="dropdown" aria-expanded="false">
                        Tableau
                    </button>
                    <ul class="dropdown-menu" style="min-width:220px">
                        <li><h6 class="dropdown-header small">Navigation rapide</h6></li>
                        <li>
                            <a class="dropdown-item" asp-controller="Issues" asp-action="Mine">
                                <span class="me-2">🎯</span> Mes tickets
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-controller="Projects" asp-action="Index">
                                <span class="me-2">📋</span> Tous les espaces
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li><h6 class="dropdown-header small">Raccourcis</h6></li>
                        <li>
                            <button class="dropdown-item" data-bs-toggle="modal" data-bs-target="#shortcutsModal">
                                <span class="me-2">⌨</span> Raccourcis clavier <kbd class="ms-1">?</kbd>
                            </button>
                        </li>
                    </ul>
                </li>
            </ul>
        }

        <div class="jira-nav-right">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Projects" asp-action="Create" class="btn btn-jira-primary btn-sm">+ Créer</a>
            }
            <button id="theme-toggle" class="btn btn-sm btn-jira-icon" title="Thème">☾</button>
            <partial name="_LoginPartial"/>
        </div>
    </nav>
</header>

<main class="@(ViewData["FullWidth"] != null ? "app-main-full" : "app-main")">
    @RenderBody()
</main>

<!-- Keyboard shortcuts modal -->
<div class="modal fade" id="shortcutsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content" style="background:var(--jira-surface);border-color:var(--jira-border)">
            <div class="modal-header border-0 pb-1">
                <h6 class="modal-title fw-bold" style="color:var(--jira-text)">⌨ Raccourcis clavier</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" style="filter:invert(0.6)"></button>
            </div>
            <div class="modal-body pt-1">
                <table class="table table-sm mb-0" style="color:var(--jira-text)">
                    <tbody>
                        <tr>
                            <td><kbd>C</kbd></td>
                            <td style="color:var(--jira-text-muted)">Créer un ticket</td>
                        </tr>
                        <tr>
                            <td><kbd>/</kbd></td>
                            <td style="color:var(--jira-text-muted)">Focus la recherche</td>
                        </tr>
                        <tr>
                            <td><kbd>Esc</kbd></td>
                            <td style="color:var(--jira-text-muted)">Effacer les filtres</td>
                        </tr>
                        <tr>
                            <td><kbd>?</kbd></td>
                            <td style="color:var(--jira-text-muted)">Ces raccourcis</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    (function () {
        var btn = document.getElementById('theme-toggle');
        if (!btn) return;
        function apply(t) {
            document.documentElement.setAttribute('data-bs-theme', t);
            btn.textContent = t === 'dark' ? '☾' : '☀';
            localStorage.setItem('td-theme', t);
        }
        apply(localStorage.getItem('td-theme') || 'dark');
        btn.addEventListener('click', function () {
            apply(document.documentElement.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark');
        });
    })();
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
