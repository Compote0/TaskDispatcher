@model WebDispatcher.Models.Project
@using WebDispatcher.Models
@{
    ViewData["Title"] = Model.Name + " — Board";
    ViewData["FullWidth"] = true;
    var statuses = Enum.GetValues<IssueStatus>();
    var board = statuses.ToDictionary(s => s, s => Model.Issues.Where(i => i.Status == s).OrderBy(i => i.IssueNumber).ToList());
    var activeSprint = Model.Sprints.FirstOrDefault(s => s.IsActive);

    var statusDotColor = new Dictionary<IssueStatus, string>
    {
        [IssueStatus.Backlog]    = "#6c757d",
        [IssueStatus.Todo]       = "#0052CC",
        [IssueStatus.InProgress] = "#00B8D9",
        [IssueStatus.InReview]   = "#FFAB00",
        [IssueStatus.Done]       = "#36B37E",
    };
    var priorityColors = new Dictionary<IssuePriority, string>
    {
        [IssuePriority.Low]      = "secondary",
        [IssuePriority.Medium]   = "warning",
        [IssuePriority.High]     = "danger",
        [IssuePriority.Critical] = "dark",
    };
    var typeIcons = new Dictionary<IssueType, string>
    {
        [IssueType.Task]    = "☑",
        [IssueType.Bug]     = "⚠",
        [IssueType.Feature] = "★",
    };
}

@Html.AntiForgeryToken()

<div class="d-flex justify-content-between align-items-center mb-3"
     data-create-url="@Url.Action("Create", "Issues", new { projectId = Model.Id })">
    <div>
        <a asp-action="Index" class="text-decoration-none small" style="color:var(--jira-text-muted)">← Espaces</a>
        <h2 class="mb-0 mt-1" style="color:var(--jira-text)">
            @Model.Name
            <span style="color:var(--jira-text-muted);font-size:.9rem;font-weight:400" class="ms-1">@Model.Key</span>
        </h2>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Issues" asp-action="Create" asp-route-projectId="@Model.Id" class="btn btn-jira-primary btn-sm px-3">+ Créer un ticket</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary">Modifier</a>
    </div>
</div>

@if (Model.Sprints.Any())
{
    <div class="sprint-panel mb-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="mb-0 fw-semibold">Sprints</h6>
            <a asp-controller="Sprints" asp-action="Create" asp-route-projectId="@Model.Id" class="btn btn-sm btn-outline-secondary">+ Nouveau</a>
        </div>
        <div class="d-flex flex-wrap gap-2">
            @foreach (var sprint in Model.Sprints.OrderByDescending(s => s.IsActive).ThenByDescending(s => s.StartDate))
            {
                <div class="d-flex align-items-center gap-2 px-3 py-2 rounded" style="background:var(--jira-surface-raised);border:1px solid var(--jira-border)">
                    <span class="fw-medium small">@sprint.Name</span>
                    <span class="small" style="color:var(--jira-text-muted)">@sprint.StartDate.ToString("d MMM") – @sprint.EndDate.ToString("d MMM")</span>
                    @if (sprint.IsActive)
                    {
                        <span class="badge sprint-badge-active">Actif</span>
                    }
                    else
                    {
                        <form asp-controller="Sprints" asp-action="Activate" asp-route-id="@sprint.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-link btn-sm p-0" style="color:var(--jira-blue)">Activer</button>
                        </form>
                    }
                </div>
            }
        </div>
    </div>
}

<div class="board-filters d-flex gap-2 align-items-center flex-wrap mb-3">
    <input type="search" id="board-search" class="board-filter-input" placeholder="🔍  Filtrer les tickets...">
    <select id="board-priority" class="board-filter-select">
        <option value="">Toutes priorités</option>
        @foreach (var p in Enum.GetValues<IssuePriority>())
        {
            <option value="@p">@p</option>
        }
    </select>
    <select id="board-type" class="board-filter-select">
        <option value="">Tous les types</option>
        @foreach (var t in Enum.GetValues<IssueType>())
        {
            <option value="@t">@t</option>
        }
    </select>
    <span class="ms-auto small" style="color:var(--jira-text-muted)">
        <kbd>C</kbd> créer &nbsp;·&nbsp; <kbd>Esc</kbd> effacer &nbsp;·&nbsp; <kbd>?</kbd> aide
    </span>
</div>

<div class="d-flex gap-3 overflow-auto pb-4 board-container align-items-start">
    @foreach (var status in statuses)
    {
        var issues = board[status];
        var dot = statusDotColor[status];
        var statusNum = (int)status;
        <div class="board-column flex-shrink-0 rounded-3 p-2" style="background:var(--jira-surface);border:1px solid var(--jira-border)">

            <div class="d-flex align-items-center gap-2 mb-3 px-1 pt-1">
                <span class="status-dot" style="background:@dot"></span>
                <span class="fw-semibold small text-uppercase letter-spacing" style="color:var(--jira-text-muted)">@status</span>
                <span class="col-count badge rounded-pill ms-auto fw-normal" style="background:var(--jira-surface-raised);color:var(--jira-text);border:1px solid var(--jira-border)">@issues.Count</span>
            </div>

            <div class="drop-zone" data-status-num="@statusNum">
                @foreach (var issue in issues)
                {
                    <div class="issue-card-wrapper mb-2"
                         draggable="true"
                         data-issue-id="@issue.Id"
                         data-status-num="@statusNum"
                         data-priority="@issue.Priority"
                         data-type="@issue.Type"
                         data-title="@issue.Title.ToLower()">
                        <div class="issue-card rounded-3 p-3">
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                <partial name="_StatusPicker" model="new StatusPickerModel { IssueId = issue.Id, Status = issue.Status }"/>
                                <span style="font-size:11px;color:var(--jira-text-muted);white-space:nowrap">@Model.Key-@issue.IssueNumber</span>
                            </div>
                            <a asp-controller="Issues" asp-action="Details" asp-route-id="@issue.Id"
                               class="issue-card-link text-decoration-none d-block" style="color:inherit">
                                <p class="mb-2 fw-medium lh-sm" style="font-size:13px;color:var(--jira-text)">@issue.Title</p>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="type-badge type-@issue.Type.ToString().ToLower()">@typeIcons[issue.Type] @issue.Type</span>
                                    <span class="badge bg-@priorityColors[issue.Priority]" style="font-size:10px">@issue.Priority</span>
                                    <div class="ms-auto d-flex align-items-center gap-1">
                                        @if (issue.DueDate.HasValue)
                                        {
                                            var overdue = issue.DueDate < DateTime.UtcNow && issue.Status != IssueStatus.Done;
                                            <span style="font-size:11px" class="@(overdue ? "text-danger fw-semibold" : "")">
                                                @issue.DueDate.Value.ToString("MMM d")
                                            </span>
                                        }
                                        @if (issue.Assignee != null)
                                        {
                                            <span class="avatar-circle" title="@issue.Assignee.UserName">
                                                @(issue.Assignee.UserName![0].ToString().ToUpper())
                                            </span>
                                        }
                                    </div>
                                </div>
                            </a>
                        </div>
                    </div>
                }

                <a asp-controller="Issues" asp-action="Create" asp-route-projectId="@Model.Id"
                   class="add-issue-btn d-block text-center text-decoration-none rounded-2 py-2 mt-1 small"
                   style="color:var(--jira-text-muted)">
                    + Ajouter un ticket
                </a>
            </div>
        </div>
    }
</div>
