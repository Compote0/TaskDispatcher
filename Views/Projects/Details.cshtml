@model WebDispatcher.Models.Project
@using WebDispatcher.Models
@{
    ViewData["Title"] = Model.Name + " — Board";
    ViewData["FullWidth"] = true;
    var statuses = Enum.GetValues<IssueStatus>();
    var board = statuses.ToDictionary(s => s, s => Model.Issues.Where(i => i.Status == s).OrderBy(i => i.IssueNumber).ToList());
    var activeSprint = Model.Sprints.FirstOrDefault(s => s.IsActive);

    var statusDotColor = new Dictionary<IssueStatus, string>
    {
        [IssueStatus.Backlog]    = "#6c757d",
        [IssueStatus.Todo]       = "#0052CC",
        [IssueStatus.InProgress] = "#00B8D9",
        [IssueStatus.InReview]   = "#FFAB00",
        [IssueStatus.Done]       = "#36B37E",
    };

    var priorityColors = new Dictionary<IssuePriority, string>
    {
        [IssuePriority.Low]      = "secondary",
        [IssuePriority.Medium]   = "warning",
        [IssuePriority.High]     = "danger",
        [IssuePriority.Critical] = "dark",
    };

    var typeIcons = new Dictionary<IssueType, string>
    {
        [IssueType.Task]    = "☑",
        [IssueType.Bug]     = "⚠",
        [IssueType.Feature] = "★",
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <a asp-action="Index" class="text-muted text-decoration-none small">← Espaces</a>
        <h2 class="mb-0 mt-1">
            @Model.Name
            <span class="text-muted fs-6 fw-normal ms-1">@Model.Key</span>
        </h2>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Issues" asp-action="Create" asp-route-projectId="@Model.Id" class="btn btn-jira-primary btn-sm px-3">+ Créer un ticket</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">Modifier</a>
    </div>
</div>

<div class="sprint-panel">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h6 class="mb-0 fw-semibold">Sprints</h6>
        <a asp-controller="Sprints" asp-action="Create" asp-route-projectId="@Model.Id" class="btn btn-sm btn-outline-secondary">+ Nouveau sprint</a>
    </div>
    @if (!Model.Sprints.Any())
    {
        <p class="text-muted small mb-0">Aucun sprint. Créez-en un pour planifier vos itérations.</p>
    }
    else
    {
        <div class="d-flex flex-wrap gap-2">
            @foreach (var sprint in Model.Sprints.OrderByDescending(s => s.IsActive).ThenByDescending(s => s.StartDate))
            {
                <div class="d-flex align-items-center gap-2 border rounded px-3 py-2" style="border-color:var(--jira-border)!important">
                    <span class="fw-medium small">@sprint.Name</span>
                    <span class="text-muted small">@sprint.StartDate.ToString("d MMM") – @sprint.EndDate.ToString("d MMM")</span>
                    @if (sprint.IsActive)
                    {
                        <span class="badge sprint-badge-active">Actif</span>
                    }
                    else
                    {
                        <form asp-controller="Sprints" asp-action="Activate" asp-route-id="@sprint.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-link btn-sm p-0">Activer</button>
                        </form>
                    }
                </div>
            }
        </div>
        @if (activeSprint != null)
        {
            <p class="text-muted small mt-2 mb-0">Sprint actif : <strong>@activeSprint.Name</strong></p>
        }
    }
</div>

<div class="d-flex gap-3 overflow-auto pb-4 board-container align-items-start">
    @foreach (var status in statuses)
    {
        var issues = board[status];
        var dot = statusDotColor[status];
        <div class="board-column flex-shrink-0 bg-body-secondary rounded-3 p-2">

            <div class="d-flex align-items-center gap-2 mb-3 px-1 pt-1">
                <span class="status-dot" style="background:@dot"></span>
                <span class="fw-semibold small text-uppercase letter-spacing">@status</span>
                <span class="badge rounded-pill bg-body border text-body ms-auto fw-normal">@issues.Count</span>
            </div>

            @foreach (var issue in issues)
            {
                <a asp-controller="Issues" asp-action="Details" asp-route-id="@issue.Id"
                   class="text-decoration-none text-body d-block mb-2">
                    <div class="issue-card bg-body rounded-3 p-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted" style="font-size:11px">@Model.Key-@issue.IssueNumber</span>
                            <span class="badge bg-@priorityColors[issue.Priority]" style="font-size:10px">@issue.Priority</span>
                        </div>
                        <p class="mb-2 fw-medium lh-sm" style="font-size:13px">@issue.Title</p>
                        <div class="d-flex align-items-center gap-2">
                            <span class="type-badge type-@issue.Type.ToString().ToLower()">@typeIcons[issue.Type] @issue.Type</span>
                            <div class="ms-auto d-flex align-items-center gap-1">
                                @if (issue.DueDate.HasValue)
                                {
                                    var overdue = issue.DueDate < DateTime.UtcNow && issue.Status != IssueStatus.Done;
                                    <span style="font-size:11px" class="@(overdue ? "text-danger fw-semibold" : "text-muted")">
                                        @issue.DueDate.Value.ToString("MMM d")
                                    </span>
                                }
                                @if (issue.Assignee != null)
                                {
                                    <span class="avatar-circle" title="@issue.Assignee.UserName">
                                        @(issue.Assignee.UserName![0].ToString().ToUpper())
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </a>
            }

            <a asp-controller="Issues" asp-action="Create" asp-route-projectId="@Model.Id"
               class="add-issue-btn d-block text-center text-muted text-decoration-none rounded-2 py-2 mt-1 small">
                + Add issue
            </a>
        </div>
    }
</div>
