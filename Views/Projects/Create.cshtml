@model WebDispatcher.Models.Project
@{
    ViewData["Title"] = "New Project";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-4">New Project</h2>

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" placeholder="My Project" autofocus />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Key" class="form-label fw-semibold"></label>
                <input asp-for="Key" class="form-control font-monospace text-uppercase" placeholder="PROJ" maxlength="10" id="keyInput" />
                <div class="form-text">Short unique identifier (e.g. PROJ, DEV). Uppercase letters and digits only.</div>
                <span asp-validation-for="Key" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="form-label fw-semibold"></label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Optional description..."></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create Project</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('keyInput').addEventListener('input', function () {
            this.value = this.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
        });
    </script>
}
