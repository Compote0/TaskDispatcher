@model WebDispatcher.Models.Project
@{
    ViewData["Title"] = "Edit — " + Model.Name;
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="mb-4">
            <a asp-action="Details" asp-route-id="@Model.Id" class="text-muted text-decoration-none small">← @Model.Name</a>
            <h2 class="mb-0">Edit Project</h2>
        </div>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="CreatedAt" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Key" class="form-label fw-semibold"></label>
                <input asp-for="Key" class="form-control font-monospace text-uppercase" maxlength="10" id="keyInput" />
                <span asp-validation-for="Key" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="form-label fw-semibold"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('keyInput').addEventListener('input', function () {
            this.value = this.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
        });
    </script>
}
