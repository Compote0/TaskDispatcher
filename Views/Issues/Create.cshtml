@model WebDispatcher.Models.Issue
@using WebDispatcher.Models
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Create Issue";
    var project = (WebDispatcher.Models.Project)ViewBag.Project;
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="mb-4">
            <a asp-controller="Projects" asp-action="Details" asp-route-id="@project.Id"
               class="text-muted text-decoration-none small">← @project.Name</a>
            <h2 class="mb-0">Create Issue</h2>
        </div>

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="ProjectId" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-semibold"></label>
                <input asp-for="Title" class="form-control" placeholder="Issue title..." autofocus />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold"></label>
                <textarea asp-for="Description" class="form-control" rows="5"
                          placeholder="Describe the issue..."></textarea>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Type" class="form-label fw-semibold"></label>
                    <select asp-for="Type" asp-items="Html.GetEnumSelectList<IssueType>()" class="form-select"></select>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Status" class="form-label fw-semibold"></label>
                    <select asp-for="Status" asp-items="Html.GetEnumSelectList<IssueStatus>()" class="form-select"></select>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Priority" class="form-label fw-semibold"></label>
                    <select asp-for="Priority" asp-items="Html.GetEnumSelectList<IssuePriority>()" class="form-select"></select>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold">Assignee</label>
                    <select asp-for="AssigneeId" asp-items="(SelectList)ViewBag.Users" class="form-select">
                        <option value="">Unassigned</option>
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="DueDate" class="form-label fw-semibold"></label>
                    <input asp-for="DueDate" type="date" class="form-control" />
                </div>
            </div>

            <div class="d-flex gap-2 mt-2">
                <button type="submit" class="btn btn-primary">Create Issue</button>
                <a asp-controller="Projects" asp-action="Details" asp-route-id="@project.Id"
                   class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
