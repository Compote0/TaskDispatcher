@model WebDispatcher.Models.Sprint
@{
    ViewData["Title"] = "Nouveau sprint";
    var project = ViewBag.Project as WebDispatcher.Models.Project;
}

<div class="mb-3">
    <a asp-controller="Projects" asp-action="Details" asp-route-id="@Model.ProjectId"
       class="text-muted text-decoration-none small">← @project?.Name</a>
</div>

<h2 class="mb-4">Nouveau sprint</h2>

<form asp-action="Create" method="post" class="col-lg-6">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ProjectId"/>

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Nom du sprint</label>
        <input asp-for="Name" class="form-control" placeholder="Sprint 1"/>
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="row mb-3">
        <div class="col">
            <label asp-for="StartDate" class="form-label">Date de début</label>
            <input asp-for="StartDate" type="date" class="form-control"/>
        </div>
        <div class="col">
            <label asp-for="EndDate" class="form-label">Date de fin</label>
            <input asp-for="EndDate" type="date" class="form-control"/>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Goal" class="form-label">Objectif (optionnel)</label>
        <textarea asp-for="Goal" class="form-control" rows="2"></textarea>
    </div>

    <div class="form-check mb-4">
        <input asp-for="IsActive" class="form-check-input"/>
        <label asp-for="IsActive" class="form-check-label">Définir comme sprint actif</label>
    </div>

    <button type="submit" class="btn btn-jira-primary">Créer le sprint</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
